{
  "expo": {
    "name": "app",
    "slug": "app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "AsphaltApp necesita tu ubicación para grabar tus rutas en moto.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "AsphaltApp necesita acceso a tu ubicación en segundo plano para seguir grabando tu ruta mientras conduces con la pantalla apagada.",
        "UIBackgroundModes": [
          "location"
        ]
      },
      "bundleIdentifier": "com.sgtwicho.asphalt"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_BACKGROUND_LOCATION",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_LOCATION"
      ],
      "package": "com.anonymous.app"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "AsphaltApp necesita tu ubicación para grabar tus rutas en moto.",
          "locationAlwaysAndWhenInUsePermission": "AsphaltApp necesita acceso a tu ubicación en segundo plano para seguir grabando tu ruta mientras conduces con la pantalla apagada.",
          "isAndroidBackgroundLocationEnabled": true,
          "isAndroidForegroundServiceEnabled": true
        }
      ],
      "expo-task-manager",
      "expo-video",
      "react-native-maps"
    ]
  }
}
